#!/bin/bash
# Sigma PPL Converter - works like: sigma convert -t opensearch-ppl

# Get script directory and project root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Activate venv if not already active
if [ -z "$VIRTUAL_ENV" ]; then
    source "$PROJECT_ROOT/.venv/bin/activate"
fi

# Run Python converter with correct PYTHONPATH
PYTHONPATH="$PROJECT_ROOT" python3 -c "
import sys
from pathlib import Path
from sigma.collection import SigmaCollection
from sigma_backend.backends.opensearch_ppl import OpenSearchPPLBackend

# Get arguments
args = sys.argv[1:]
if len(args) < 1:
    print('Usage: sigma-ppl <rule.yml> [-o output.ppl]')
    sys.exit(1)

input_file = args[0]

with open(input_file, 'r') as f:
    sigma_content = f.read()

collection = SigmaCollection.from_yaml(sigma_content)
backend = OpenSearchPPLBackend()
ppl_query = backend.convert(collection)

# Handle output
if len(args) >= 3 and args[1] == '-o':
    with open(args[2], 'w') as f:
        f.write(ppl_query)
    print(f'✓ Converted to: {args[2]}')
else:
    print(ppl_query)
" "$@"
