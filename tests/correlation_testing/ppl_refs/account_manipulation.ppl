# Account Manipulation Detection - OpenSearch PPL Translation
# Detects backdoor account creation followed by privilege escalation (in strict order within 5 minutes)

source=windows-security
| where EventID in (4720, 4732)
| where EventID=4732 implies TargetUserName in ('Administrators', 'Domain Admins', 'Enterprise Admins')
| bin @timestamp span=5m as time_window
| eval account_name = if(EventID=4720, TargetUserName, 
                        if(EventID=4732, MemberName, null))
| eval event_order = if(EventID=4720, 1, if(EventID=4732, 2, 0))
| sort + @timestamp
| stats earliest(eval(event_order=1, @timestamp, null)) as creation_time,
        earliest(eval(event_order=2, @timestamp, null)) as escalation_time,
        count(eval(event_order=1)) as creation_events,
        count(eval(event_order=2)) as escalation_events,
        values(eval(EventID=4732, TargetUserName, null)) as privileged_groups,
        values(SubjectUserName) as actors
  by time_window, account_name, ComputerName
| where creation_events > 0 and escalation_events > 0
| where creation_time < escalation_time
| eval sequence_duration_seconds = (escalation_time - creation_time) / 1000
| fields time_window, account_name, ComputerName, creation_time, escalation_time,
        sequence_duration_seconds, privileged_groups, actors
        count(eval(EventID=4732)) as escalations
  by time_window, user
| where creations > 0 and escalations > 0 and created_at < privileged_at
| eval delta_seconds = (privileged_at - created_at) / 1000
| fields time_window, user, created_at, privileged_at, delta_seconds

# Explanation:
# 1. Ordered temporal correlation requires events in SPECIFIC ORDER
# 2. EventID 4720 = account creation must occur BEFORE EventID 4732 = group addition
# 3. Field aliases: TargetUserName (creation) maps to MemberName (group addition)
# 4. Use earliest() and latest() with eval to track timestamps per event type
# 5. Critical check: creation_timestamp < privilege_timestamp (enforces order)
# 6. 5-minute window captures quick privilege escalation attempts
# 7. Sort by @timestamp to maintain chronological order
# 8. This pattern detects backdoor account creation with immediate privileging
# 9. More restrictive than simple temporal - ORDER MATTERS
# 10. Calculate time delta to measure speed of attack progression
