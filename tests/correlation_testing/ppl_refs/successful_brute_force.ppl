# Successful Brute Force Detection - OpenSearch PPL Translation
# Detects successful brute force (failed attempts followed by success in 10 minutes)

source=windows-security
| where EventID in (4625, 4624) and LogonType=3
| bin @timestamp span=10m as time_window
| eval event_type = if(EventID=4625, 'failed', if(EventID=4624, 'success', 'other'))
| stats count() as total_events,
        dc(event_type) as event_types_present,
        values(event_type) as event_types,
        count(eval(event_type='failed')) as failed_attempts,
        count(eval(event_type='success')) as successful_logins,
        min(@timestamp) as first_event,
        max(@timestamp) as last_event
  by time_window, IpAddress, TargetUserName
| where event_types_present >= 2 and failed_attempts > 0 and successful_logins > 0
| fields time_window, IpAddress, TargetUserName, failed_attempts, 
        successful_logins, first_event, last_event
