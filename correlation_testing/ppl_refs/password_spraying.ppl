# Password Spraying Detection - OpenSearch PPL Translation
# Detects password spraying attacks (10+ distinct accounts from same IP in 30 minutes)

source=windows-security
| where EventID=4625
| bin @timestamp span=30m as time_window
| stats dc(TargetUserName) as distinct_users,
        count() as total_attempts,
        values(TargetUserName) as targeted_accounts
  by time_window, IpAddress
| where distinct_users >= 10
| fields time_window, IpAddress, distinct_users, total_attempts, targeted_accounts
