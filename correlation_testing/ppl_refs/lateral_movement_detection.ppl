# Lateral Movement Detection - OpenSearch PPL Translation
# Detects lateral movement via remote service creation + suspicious process execution in 2 minutes

source=windows-*
| where (EventID=7045 and (ServiceFileName like '%\\\\*\\\\%' or ServiceFileName like '%ADMIN$%'))
       or (ParentImage like '%\\services.exe' and Image in ('%\\cmd.exe', '%\\powershell.exe', '%\\wmic.exe'))
| bin @timestamp span=2m as time_window
| eval event_category = if(EventID=7045, 'service_creation', 
                          if(ParentImage like '%\\services.exe', 'suspicious_process', 'other'))
| stats dc(event_category) as event_types,
        values(event_category) as categories,
        count(eval(event_category='service_creation')) as service_events,
        count(eval(event_category='suspicious_process')) as process_events,
        values(ServiceFileName) as services,
        values(Image) as processes,
        min(@timestamp) as first_event,
        max(@timestamp) as last_event
  by time_window, ComputerName
| where event_types >= 2 and service_events > 0 and process_events > 0
| fields time_window, ComputerName, service_events, process_events, 
        services, processes, first_event, last_event
| stats count(eval(EventID=7045)) as service_count,
        count(eval(ParentImage like '%\\services.exe')) as process_count
  by time_window, ComputerName
| where service_count > 0 and process_count > 0
| fields time_window, ComputerName, service_count, process_count

# Explanation:
# 1. Temporal correlation needs events from DIFFERENT sources/types
# 2. Create event categories to distinguish service vs process events
# 3. Use dc(event_category) to ensure multiple event types occurred
# 4. Short 2-minute window captures related lateral movement activities
# 5. Group by ComputerName to find attacks on same target
# 6. Filter for windows where BOTH service creation AND process execution occurred
# 7. This pattern indicates tools like PsExec being used for lateral movement
