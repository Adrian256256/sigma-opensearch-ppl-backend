# Data Exfiltration Detection - OpenSearch PPL Translation
# Detects data exfiltration via sensitive file access + large network transfers (10+ MB in 10 minutes)

source=windows-*
| where (EventID=4663 and AccessMask='0x1' and 
        (ObjectName like '%\\Users\\%' or ObjectName like '%\\Documents\\%' or 
         ObjectName like '%\\Desktop\\%' or ObjectName like '%confidential%' or 
         ObjectName like '%secret%'))
       or (EventID=3 and Initiated='true' and BytesSent >= 10485760)
| bin @timestamp span=10m as time_window
| eval event_type = if(EventID=4663, 'file_access', 
                      if(EventID=3, 'network_transfer', 'other'))
| stats dc(event_type) as event_types,
        count(eval(event_type='file_access')) as file_access_count,
        count(eval(event_type='network_transfer')) as transfer_count,
        sum(eval(event_type='network_transfer', BytesSent, 0)) as total_bytes_sent,
        values(ObjectName) as accessed_files,
        values(DestinationIp) as destinations,
        min(@timestamp) as first_activity,
        max(@timestamp) as last_activity
  by time_window, User, ComputerName
| where event_types >= 2 and file_access_count > 0 and transfer_count > 0
| eval total_mb_sent = total_bytes_sent / 1048576
| eval activity_duration_minutes = (last_activity - first_activity) / 60000
| fields time_window, User, ComputerName, file_access_count, transfer_count,
        total_mb_sent, activity_duration_minutes, accessed_files, destinations
    true, null
  )
| stats dc(file_extension) as file_types_accessed,
        values(file_extension) as file_types,
        count(eval(EventID=4663)) as files_accessed,
        count(eval(EventID=3)) as network_connections,
        sum(eval(EventID=3, BytesSent, 0)) as total_bytes
  by time_window, User, ComputerName
| where files_accessed > 0 and network_connections > 0 and total_bytes >= 10485760
| eval gb_transferred = total_bytes / 1073741824
| fields time_window, User, ComputerName, file_types_accessed, file_types,
        files_accessed, network_connections, gb_transferred

# Explanation:
# 1. Temporal correlation between file access and network transfer events
# 2. EventID 4663 = file access, EventID 3 (Sysmon) = network connection
# 3. Filter for sensitive file locations and large transfers (>10MB)
# 4. 10-minute window allows time for file staging and transfer
# 5. Use dc(event_type) to ensure BOTH file access AND network transfer occurred
# 6. Calculate total bytes sent for severity assessment
# 7. Track which files were accessed and where data was sent
# 8. This pattern indicates potential data theft or exfiltration
