# Privileged Group Enumeration Detection - OpenSearch PPL Translation
# Detects BloodHound-style enumeration of privileged groups (4+ distinct groups in 15 minutes)

source=windows-security
| where EventID=4799 and CallerProcessId='0x0'
| where TargetUserName in ('Administrators', 'Remote Desktop Users', 'Remote Management Users', 'Distributed COM Users')
| bin @timestamp span=15m as time_window
| stats dc(TargetUserName) as distinct_groups, 
        values(TargetUserName) as groups_accessed,
        count() as total_events 
  by time_window, SubjectUserName, ComputerName
| where distinct_groups >= 4
| fields time_window, SubjectUserName, ComputerName, distinct_groups, groups_accessed, total_events
